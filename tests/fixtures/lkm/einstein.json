      "metadata": null
    },
    {
      "id": "github:einstein_gravity::prior_knowledge__soldner_deflection",
      "type": "claim",
      "visibility": "public",
      "content": "Soldner 1801 年基于牛顿力学将光视为质点（微粒说），   计算得光线掠过太阳表面时偏折：   θ_Newton = (2 G M_⊙)/(c^2 R_⊙) ≈ 0.87''",
      "content_hash": "ad2859d59d9ebbf2d31f5fa6bbda9091a8934191ae105f55fd15d09b4f86ca08",
      "parameters": [],
      "source_package": "einstein_gravity",
      "version": "4.0.0",
      "metadata": null
    },
    {
      "id": "github:einstein_gravity::equivalence_principle__elevator_env",
      "type": "setting",
      "visibility": "public",
      "content": "密闭电梯思想实验：电梯中的观察者无法看到外界，   需要判断自己是静止在引力场中还是在无引力空间中匀加速上升。",
      "content_hash": "72512d4a4cd7e1006d04b29a8baa0dcd198e227471801dbd86d461e4dabfa994",
      "parameters": [],
