      "metadata": null
    },
    {
      "id": "github:einstein_gravity::equivalence_principle__equivalence_principle",
      "type": "claim",
      "visibility": "public",
      "content": "爱因斯坦等价原理：在足够小的时空区域内，   均匀引力场的效应与匀加速参考系的效应不可区分。",
      "content_hash": "d2e30e3a7a3e8508e0a1322375c4e2f9cbfbd59e1b1a0baeb235213bfd9bceb7",
      "parameters": [],
      "source_package": "einstein_gravity",
      "version": "4.0.0",
      "metadata": null
    },
    {
      "id": "github:einstein_gravity::equivalence_principle__light_bends_in_gravity",
      "type": "claim",
      "visibility": "public",
      "content": "光线在引力场中会发生弯曲。",
      "content_hash": "9ea7e973e724873d1a5c1a0844d04e37fed047a74b5b59f140cd65edf3b038d7",
      "parameters": [],
      "source_package": "einstein_gravity",
