      "representative_lcn": null,
      "local_members": null
    },
    {
      "id": "reg:newton_principia::observations__pendulum_experiment",
      "label": "observations__pendulum_experiment",
      "type": "claim",
      "content": "牛顿用等长摆锤悬挂金、银、铅、玻璃、沙、盐、木、水、小麦等不同材料，   测得所有材料的摆动周期在   10^−3   精度内完全一致。",
      "content_hash": "81d7c3f74015e576e8101967e2b5bd578c5df04569ef60d459643deabdd5a3af",
      "parameters": [],
      "metadata": {
        "kind": "observation"
