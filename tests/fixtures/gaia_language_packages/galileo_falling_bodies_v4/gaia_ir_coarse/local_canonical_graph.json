      "local_members": null
    },
    {
      "id": "reg:galileo_falling_bodies::galileo__medium_density_observation",
      "label": "galileo__medium_density_observation",
      "type": "claim",
      "content": "在水、油、空气等不同介质中比较轻重物体的下落，   会发现介质越稠密，速度差异越明显；介质越稀薄，差异越不明显。",
      "content_hash": "0606822aa306a2585dc500067279a4e5916eb34aa3c896e8e66c83bf4353b1ad",
      "parameters": [],
      "metadata": {
