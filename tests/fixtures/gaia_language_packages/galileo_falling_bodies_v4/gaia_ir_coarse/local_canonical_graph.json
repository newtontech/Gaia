      "provenance": null,
      "representative_lcn": null,
      "local_members": null
    },
    {
      "id": "reg:galileo_falling_bodies::aristotle__heavier_falls_faster",
      "label": "aristotle__heavier_falls_faster",
      "type": "claim",
      "content": "物体下落的速度与其重量成正比——重者下落更快。",
      "content_hash": "db2ff34baace353929e4c27ab0d81202c2cb125dfb357849e34ddebd074aebfd",
      "parameters": [],
      "metadata": null,
      "provenance": null,
