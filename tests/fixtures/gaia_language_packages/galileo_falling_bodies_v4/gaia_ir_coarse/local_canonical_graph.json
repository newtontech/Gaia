      "local_members": null
    },
    {
      "id": "reg:galileo_falling_bodies::aristotle__everyday_observation",
      "label": "aristotle__everyday_observation",
      "type": "claim",
      "content": "日常生活中，石头比羽毛下落更快、   铁球比木球更快，似乎重者总是先着地。",
      "content_hash": "6200cde723f9ce2fec7bd12f911d9f0e672af820b180a2d01ef0508d88a51b51",
      "parameters": [],
      "metadata": {
