          "version": "1.0.0"
        }
      ],
      "metadata": null,
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "对地表附近的自由落体：m × a = m × g，约去质量得 a = g。 自由落体加速度等于引力场强度，与物体的质量无关。\n"
    },
    {
      "global_canonical_id": "gcn_4a3ec52449c500b2",
      "kind": null,
      "knowledge_type": "claim",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_7a03cda4ec534c19",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": null,
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "在同一引力场中，所有物体的自由落体加速度相同，与质量无关。 这是牛顿力学的理论推论，不依赖于任何具体实验。\n"
    },
    {
      "global_canonical_id": "gcn_ab2926ac96fc5554",
      "kind": null,
      "knowledge_type": "equivalence",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_679585c3ffaede4c",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": {
        "between": [
          "acceleration_independent_of_mass",
          "galileo_vacuum_prediction"
        ]
      },
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "牛顿从 F=ma 和 F=mg 推导出的\"a=g 与质量无关\" 与伽利略从思想实验和经验分析预测的\"真空中不同重量物体等速下落\" 在物理含义上等价。 区别在于：伽利略是经验论证（归谬法 + 介质分析 + 斜面实验）， 牛顿是理论推导（从基本定律出发的演绎）。\n"
    },
    {
      "global_canonical_id": "gcn_0a2af52d1a35f489",
      "kind": null,
      "knowledge_type": "claim",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_390e41f5e4271931",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": null,
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "牛顿的 a=g 推导从理论上排除了\"下落速度与重量成正比\"的可能： 如果加速度不依赖质量，那么亚里士多德的 v∝W 就不是自然界的规律。 这与伽利略的归谬法反驳独立，提供了第二条反驳路径。\n"
    },
    {
      "global_canonical_id": "gcn_d0bf92d3eff04320",
      "kind": null,
      "knowledge_type": "claim",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_051bcb61bd2c88c1",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": null,
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "亚里士多德落体学说同时遭到两条方法上不同的反驳路径削弱： 伽利略通过绑球归谬法暴露其内在矛盾， 牛顿则从更基本的力学定律推导出与之不相容的结果。 两条路径相互独立地汇聚到同一结论。\n"
    },
    {
      "global_canonical_id": "gcn_896c1af0a3a18376",
      "kind": null,
      "knowledge_type": "contradiction",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_f3d163a634b10ae3",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": {
        "between": [
          "acceleration_independent_of_mass",
          "aristotle_law"
        ]
      },
      "parameters": [],
      "provenance": [
        {
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "representative_content": "牛顿的 a=g（加速度与质量无关）直接矛盾于 亚里士多德的 v∝W（下落速度与重量成正比）。 前者是理论推导，后者是未经控制的经验归纳。\n"
    },
    {
      "global_canonical_id": "gcn_591d398924bb1152",
      "kind": "infer_action",
      "knowledge_type": "action",
      "member_local_nodes": [
        {
          "local_canonical_id": "lcn_cc1deda139d9572d",
          "package": "newton_principia",
          "version": "1.0.0"
        }
      ],
      "metadata": null,
